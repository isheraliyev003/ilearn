DATABASE_URL="postgresql://..."
CORS_ORIGIN="http://localhost:3000"

# Email auth
RESEND_API_KEY="re_..."
EMAIL_FROM="ilearn <auth@example.com>"
# In local development, if these are unset or email delivery fails,
# the backend logs the 6-digit auth code to the terminal.

# Optional AI translation provider
AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
SERPER_API_KEY=""
